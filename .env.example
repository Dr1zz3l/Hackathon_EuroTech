# Copy this file to `.env` (same directory) and fill in your key.
# `.env` is gitignored — never commit a real key.
# (This .env.example file IS tracked by git — keep only placeholders here.)

# Required for the LLM backend (parse-goal, explain, summarize-plan, chat).
ANTHROPIC_API_KEY=sk-ant-...

# Optional — model for the conversational assistant (/api/chat).
# Defaults to claude-sonnet-4-6 if unset.
# CHAT_MODEL=claude-sonnet-4-6

# Optional — enables the real TabPFN model (PriorLabs) for the predict tool.
# Without it, predictions fall back to a labelled kNN baseline.
# Get a token: log in at https://ux.priorlabs.ai, accept the licence,
# then copy your key from https://ux.priorlabs.ai/account
# TABPFN_TOKEN=
